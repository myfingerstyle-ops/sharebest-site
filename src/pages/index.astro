---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const sortByDate = (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf();

const reviews = (await getCollection("reviews")).sort(sortByDate);
const guides = (await getCollection("guides")).sort(sortByDate);

const reviewPool = reviews.filter((entry) => entry.data.featured);
const guidePool = guides.filter((entry) => entry.data.featured);

const featuredReviews = (reviewPool.length > 0 ? reviewPool : reviews).slice(0, 3);
const featuredGuides = (guidePool.length > 0 ? guidePool : guides).slice(0, 3);
const heroReview = featuredReviews[0];
const heroGuide = featuredGuides[0];

const latestArticles = [
  ...reviews.map((entry) => ({ entry, href: "/reviews/" + entry.slug + "/" })),
  ...guides.map((entry) => ({ entry, href: "/guides/" + entry.slug + "/" }))
]
  .sort((a, b) => b.entry.data.publishDate.valueOf() - a.entry.data.publishDate.valueOf())
  .slice(0, 6);

const spotlightArticles = reviews.slice(0, 3);

const categoryMap = new Map();
[...reviews, ...guides].forEach((entry) => {
  const current = categoryMap.get(entry.data.category);
  if (current) {
    current.count += 1;
  } else {
    categoryMap.set(entry.data.category, {
      slug: entry.data.category,
      label: entry.data.categoryLabel,
      count: 1
    });
  }
});

const categories = [...categoryMap.values()].sort((a, b) => b.count - a.count).slice(0, 6);
const totalArticles = reviews.length + guides.length;

const editorialScenes = [
  {
    image: "/images/reviews/review-home-office-chair-cover.jpg",
    alt: "Comfortable home office corner with a modern chair and warm natural light",
    title: "Comfort-first home office upgrades",
    body: "Lifestyle-led imagery makes practical recommendations feel closer to a real home instead of a catalog page."
  },
  {
    image: "/images/reviews/review-kitchen-organizer-cover.jpg",
    alt: "Organized kitchen shelves with containers and daily-use storage products",
    title: "Storage scenes that feel lived in",
    body: "Organizing products look more trustworthy when they appear inside believable everyday spaces with texture and warmth."
  },
  {
    image: "/images/reviews/review-orthopedic-dog-bed-cover.jpg",
    alt: "Relaxed dog resting on a supportive bed inside a calm living room",
    title: "Pet products shown in real routines",
    body: "Real pets, real rooms, and matching product context help the site feel more like editorial media and less like ecommerce."
  }
];

const trustPoints = [
  {
    title: "Clear summaries first",
    body: "Every article starts with the verdict, the tradeoffs, and who the pick fits best."
  },
  {
    title: "Everyday product focus",
    body: "Coverage is built around home, pets, cleaning, storage, and practical daily upgrades."
  },
  {
    title: "Fast browsing experience",
    body: "Simple layouts, visual cards, and direct category links help readers compare faster."
  }
];
---

<BaseLayout title={site.name} description={site.description}>
  <section class="hero hero-upgraded hero-rich-home">
    <div class="hero-ambient" aria-hidden="true">
      <span class="hero-ambient-orb hero-ambient-orb-one"></span>
      <span class="hero-ambient-orb hero-ambient-orb-two"></span>
      <span class="hero-ambient-grid"></span>
    </div>

    <div class="container hero-grid hero-grid-upgraded hero-grid-rich">
      <div class="hero-card hero-copy hero-copy-upgraded">
        <div class="hero-kicker-row">
          <span class="hero-kicker-pill">English edition</span>
          <span class="hero-kicker-copy">Practical buying research for home, pets, and daily life</span>
        </div>
        <p class="eyebrow">Curated product reviews</p>
        <h1>Useful product picks with a cleaner, more premium reading experience.</h1>
        <p>
          ShareBest helps readers compare practical products faster through concise summaries, image-rich layouts, and simple category browsing that feels polished without becoming cluttered.
        </p>
        <div class="hero-actions">
          <a class="button" href={site.heroCtaPrimary}>Browse reviews</a>
          <a class="button-secondary" href={site.heroCtaSecondary}>Read buying guides</a>
        </div>
        <div class="hero-trust-row">
          <span>Editorial layouts</span>
          <span>Visual product guides</span>
          <span>Simple pros and cons</span>
        </div>
        <div class="hero-proof-grid">
          <div class="hero-proof-card">
            <strong>{totalArticles}+</strong>
            <span>published reads</span>
          </div>
          <div class="hero-proof-card">
            <strong>{categories.length}</strong>
            <span>core categories</span>
          </div>
          <div class="hero-proof-card">
            <strong>{reviews.length}</strong>
            <span>review articles</span>
          </div>
        </div>
      </div>

      <div class="hero-card hero-visual hero-visual-rich">
        <div class="hero-image-frame">
          <img
            src="/images/site/hero/home-hero-editorial.jpg"
            alt="Editorial-style home and pet product scene for ShareBest homepage"
            class="hero-visual-image"
          />
        </div>

        <div class="hero-support-grid">
          {heroReview ? (
            <a class="hero-feature-card primary" href={"/reviews/" + heroReview.slug + "/"}>
              <span class="hero-feature-label">Featured review</span>
              <h3>{heroReview.data.title}</h3>
              <p>{heroReview.data.description}</p>
              <div class="hero-feature-meta">
                <span>{heroReview.data.categoryLabel}</span>
                {heroReview.data.rating && <strong>{heroReview.data.rating}/10</strong>}
              </div>
            </a>
          ) : null}

          {heroGuide ? (
            <a class="hero-feature-card secondary" href={"/guides/" + heroGuide.slug + "/"}>
              <span class="hero-feature-label">Reader guide</span>
              <h3>{heroGuide.data.title}</h3>
              <p>{heroGuide.data.description}</p>
            </a>
          ) : null}
        </div>
      </div>
    </div>
  </section>

  <section class="section section-tight-top">
    <div class="container">
      <div class="stats-grid">
        <div class="card stat">
          <strong>{totalArticles}</strong>
          <span>Published articles</span>
        </div>
        <div class="card stat">
          <strong>{reviews.length}</strong>
          <span>Review articles</span>
        </div>
        <div class="card stat">
          <strong>{guides.length}</strong>
          <span>Buying guides</span>
        </div>
        <div class="card stat">
          <strong>{categories.length}</strong>
          <span>Core categories</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Editorial spotlight</p>
          <h2>A richer first screen for practical shopping research</h2>
        </div>
      </div>

      <div class="spotlight-grid">
        {spotlightArticles[0] && (
          <a class="spotlight-card spotlight-card-large" href={"/reviews/" + spotlightArticles[0].slug + "/"}>
            {spotlightArticles[0].data.heroImage && (
              <img src={spotlightArticles[0].data.heroImage} alt={spotlightArticles[0].data.title} class="spotlight-image" />
            )}
            <div class="spotlight-body">
              <span class="hero-feature-label">Editor pick</span>
              <h3>{spotlightArticles[0].data.title}</h3>
              <p>{spotlightArticles[0].data.description}</p>
            </div>
          </a>
        )}

        <div class="spotlight-stack">
          {spotlightArticles.slice(1).map((entry) => (
            <a class="spotlight-card" href={"/reviews/" + entry.slug + "/"}>
              {entry.data.heroImage && <img src={entry.data.heroImage} alt={entry.data.title} class="spotlight-image" />}
              <div class="spotlight-body">
                <span class="hero-feature-label">Popular review</span>
                <h3>{entry.data.title}</h3>
                <p>{entry.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading section-heading-stack">
        <div>
          <p class="eyebrow">Visual direction</p>
          <h2>Real-life scenes that make the site feel more like a lifestyle publication</h2>
          <p class="section-subcopy">
            The next layer of polish comes from showing products inside believable home and pet routines with richer photographic storytelling.
          </p>
        </div>
      </div>
      <div class="grid grid-3">
        {editorialScenes.map((scene) => (
          <article class="spotlight-card">
            <img src={scene.image} alt={scene.alt} class="spotlight-image" />
            <div class="spotlight-body">
              <span class="hero-feature-label">Editorial image direction</span>
              <h3>{scene.title}</h3>
              <p>{scene.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Featured reviews</p>
          <h2>Start with our most useful product picks</h2>
        </div>
        <a href="/reviews/">See all reviews</a>
      </div>
      <div class="grid grid-3">
        {featuredReviews.map((entry) => (
          <ArticleCard
            href={"/reviews/" + entry.slug + "/"}
            title={entry.data.title}
            description={entry.data.description}
            categoryLabel={entry.data.categoryLabel}
            publishDate={entry.data.publishDate}
            image={entry.data.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Buying guides</p>
          <h2>Helpful reads for smarter comparisons</h2>
        </div>
        <a href="/guides/">See all guides</a>
      </div>
      <div class="grid grid-3">
        {featuredGuides.map((entry) => (
          <ArticleCard
            href={"/guides/" + entry.slug + "/"}
            title={entry.data.title}
            description={entry.data.description}
            categoryLabel={entry.data.categoryLabel}
            publishDate={entry.data.publishDate}
            image={entry.data.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading section-heading-stack">
        <div>
          <p class="eyebrow">Shop by category</p>
          <h2>Browse the site by topic</h2>
          <p class="section-subcopy">Jump straight into the product type you care about most.</p>
        </div>
      </div>
      <div class="category-grid">
        {categories.map((category) => (
          <a class="category-card" href={"/category/" + category.slug + "/"}>
            <span class="category-card-count">{category.count} article{category.count > 1 ? "s" : ""}</span>
            <h3>{category.label}</h3>
            <p>Explore reviews and guides related to {category.label.toLowerCase()}.</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-soft">
    <div class="container">
      <div class="section-heading section-heading-stack">
        <div>
          <p class="eyebrow">Why trust ShareBest</p>
          <h2>Built for fast, low-stress product research</h2>
        </div>
      </div>
      <div class="trust-grid">
        {trustPoints.map((item) => (
          <div class="card trust-card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Latest articles</p>
          <h2>New and recently updated reads</h2>
        </div>
      </div>
      <div class="grid grid-3">
        {latestArticles.map(({ entry, href }) => (
          <ArticleCard
            href={href}
            title={entry.data.title}
            description={entry.data.description}
            categoryLabel={entry.data.categoryLabel}
            publishDate={entry.data.publishDate}
            image={entry.data.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="cta-panel">
        <div>
          <p class="eyebrow">Next up</p>
          <h2>More image-rich reviews are on the way.</h2>
          <p>
            ShareBest is expanding with richer article galleries, better internal linking, and stronger visual storytelling across reviews and guides.
          </p>
        </div>
        <div class="hero-actions">
          <a class="button" href="/reviews/">Explore reviews</a>
          <a class="button-secondary button-secondary-light" href="/about/">Learn about ShareBest</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
