---
import { getCollection } from "astro:content";
import ArticleCard from "../components/ArticleCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";

const sortByDate = (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf();

const reviews = (await getCollection("reviews")).sort(sortByDate);
const guides = (await getCollection("guides")).sort(sortByDate);
const featuredReviews = reviews.filter((entry) => entry.data.featured).slice(0, 3);
const latestGuides = guides.slice(0, 3);

const categoryMap = new Map();
[...reviews, ...guides].forEach((entry) => {
  if (categoryMap.has(entry.data.category) === false) {
    categoryMap.set(entry.data.category, entry.data.categoryLabel);
  }
});
const categories = [...categoryMap.entries()].map(([slug, label]) => ({ slug, label }));
---

<BaseLayout title={site.name} description={site.description}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-card hero-copy">
        <p class="eyebrow">Honest product picks</p>
        <h1>Practical reviews for better everyday buys.</h1>
        <p>
          ShareBest publishes clear reviews, simple buying advice, and easy category guides for readers who want faster, less confusing product research.
        </p>
        <div class="hero-actions">
          <a class="button" href={site.heroCtaPrimary}>Browse reviews</a>
          <a class="button-secondary" href={site.heroCtaSecondary}>Read guides</a>
        </div>
      </div>
      <div class="hero-card hero-highlight">
        <h2>What you will find here</h2>
        <ul class="check-list">
          <li>Short, practical reviews for everyday products</li>
          <li>Simple buying guides written in plain English</li>
          <li>Clear pros, cons, and best-fit use cases</li>
          <li>Launch-phase coverage starting with pet and home essentials</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="stats-grid">
        <div class="card stat">
          <strong>{reviews.length}</strong>
          <span>Review articles</span>
        </div>
        <div class="card stat">
          <strong>{guides.length}</strong>
          <span>Buying guides</span>
        </div>
        <div class="card stat">
          <strong>{categories.length}</strong>
          <span>Core categories</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Featured</p>
          <h2>Start with our highlighted reviews</h2>
        </div>
        <a href="/reviews/">See all reviews</a>
      </div>
      <div class="grid grid-3">
        {featuredReviews.map((entry) => (
          <ArticleCard
            href={`/reviews/${entry.slug}/`}
            title={entry.data.title}
            description={entry.data.description}
            categoryLabel={entry.data.categoryLabel}
            publishDate={entry.data.publishDate}
            image={entry.data.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Guides</p>
          <h2>Helpful reads for smarter comparisons</h2>
        </div>
        <a href="/guides/">See all guides</a>
      </div>
      <div class="grid grid-3">
        {latestGuides.map((entry) => (
          <ArticleCard
            href={`/guides/${entry.slug}/`}
            title={entry.data.title}
            description={entry.data.description}
            categoryLabel={entry.data.categoryLabel}
            publishDate={entry.data.publishDate}
            image={entry.data.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Explore</p>
          <h2>Browse by category</h2>
        </div>
      </div>
      <div class="category-links">
        {categories.map((category) => (
          <a href={`/category/${category.slug}/`}>{category.label}</a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>