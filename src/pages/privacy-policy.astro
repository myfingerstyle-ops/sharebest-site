---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="Privacy Policy" description="Privacy policy for ShareBest.">
  <section class="page-hero">
    <div class="container">
      <div class="panel page-intro page-copy">
        <p class="eyebrow">Legal</p>
        <h1>Privacy Policy</h1>
        <p>
          This website is a simple content site. We do not provide user accounts, public comments, or member dashboards in this MVP version.
        </p>
        <h2>Information we collect</h2>
        <p>
          We may receive basic analytics or standard server-side request data through website hosting and performance tools.
        </p>
        <h2>How information is used</h2>
        <p>
          Any basic technical information is used to understand site traffic, maintain performance, and improve content quality.
        </p>
        <h2>Third-party links</h2>
        <p>
          Some pages may link to third-party websites. Their privacy practices are controlled by their own policies, not this site.
        </p>
        <h2>Contact</h2>
        <p>
          If you have a privacy-related question, contact us at <a href={`mailto:${site.email}`}>{site.email}</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>