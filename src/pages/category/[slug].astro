---
import { getCollection } from "astro:content";
import ArticleCard from "../../components/ArticleCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const reviews = await getCollection("reviews");
  const guides = await getCollection("guides");
  const categoryMap = new Map();

  [...reviews, ...guides].forEach((entry) => {
    categoryMap.set(entry.data.category, entry.data.categoryLabel);
  });

  return [...categoryMap.entries()].map(([slug, label]) => ({
    params: { slug },
    props: { label }
  }));
}

const { label } = Astro.props;
const slug = Astro.params.slug;

const reviews = (await getCollection("reviews"))
  .filter((entry) => entry.data.category === slug)
  .map((entry) => ({ ...entry, href: `/reviews/${entry.slug}/` }));

const guides = (await getCollection("guides"))
  .filter((entry) => entry.data.category === slug)
  .map((entry) => ({ ...entry, href: `/guides/${entry.slug}/` }));

const items = [...reviews, ...guides].sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout title={label} description={`Browse ${label.toLowerCase()} articles on ShareBest.`}>
  <section class="page-hero">
    <div class="container">
      <div class="panel page-intro">
        <p class="eyebrow">Category</p>
        <h1>{label}</h1>
        <p>
          Explore all reviews and guides currently filed under this topic.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {items.length ? (
        <div class="grid grid-3">
          {items.map((entry) => (
            <ArticleCard
              href={entry.href}
              title={entry.data.title}
              description={entry.data.description}
              categoryLabel={entry.data.categoryLabel}
              publishDate={entry.data.publishDate}
              image={entry.data.heroImage}
            />
          ))}
        </div>
      ) : (
        <div class="panel empty-state">
          <h2>No articles yet</h2>
          <p>Check back soon for new content in this category.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>