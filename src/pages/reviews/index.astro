---
import { getCollection } from "astro:content";
import ArticleCard from "../../components/ArticleCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const reviews = (await getCollection("reviews")).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout title="Reviews" description="Browse practical product reviews on ShareBest.">
  <section class="page-hero">
    <div class="container">
      <div class="panel page-intro">
        <p class="eyebrow">Reviews</p>
        <h1>Practical product reviews that get to the point.</h1>
        <p>
          Browse quick, useful reviews across our current launch categories, including pet and home essentials.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {reviews.map((entry) => (
          <ArticleCard
            href={`/reviews/${entry.slug}/`}
            title={entry.data.title}
            description={entry.data.description}
            categoryLabel={entry.data.categoryLabel}
            publishDate={entry.data.publishDate}
            image={entry.data.heroImage}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>